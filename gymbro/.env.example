# Plantilla del .env de gymbro.ai — copia a .env y rellena valores reales.
# El .env nunca se sube al repo (ver .gitignore raíz).

# --- Credenciales del panel admin ---
# Solo TÚ entras a la web. Define usuario y contraseña fuertes.
ADMIN_USER=admin
# Opción A — contraseña en texto plano (rápido, menos seguro):
ADMIN_PASSWORD=cambia-esto-por-una-pass-larga
# Opción B — hash bcrypt (recomendado en producción). Genera con:
#   docker run --rm node:20-alpine sh -c 'node -e "console.log(require(\"bcryptjs\").hashSync(process.argv[1], 10))" "tu-pass"'
# Si pones ADMIN_PASSWORD_HASH, ADMIN_PASSWORD se ignora.
ADMIN_PASSWORD_HASH=

# --- JWT para la sesión del admin ---
# Cualquier string aleatorio largo (32+ chars). Ejemplo: openssl rand -hex 32
JWT_SECRET=cambia-esto-por-un-secreto-largo-aleatorio

# --- Anthropic (Claude Haiku 4.5) ---
# Crea la key en https://console.anthropic.com → API keys
ANTHROPIC_API_KEY=sk-ant-...
# Modelo por defecto (deja el default si no necesitas cambiarlo):
CLAUDE_MODEL=claude-haiku-4-5

# --- Zona horaria para crons y formato de horas ---
TIMEZONE=Europe/Madrid

# --- Comportamiento ---
# Si está a true, al arrancar el contenedor intenta reconectar usando la sesión
# de WhatsApp guardada en disco (si la cerraste por logout, NO reconecta).
AUTOSTART_BOT=true
