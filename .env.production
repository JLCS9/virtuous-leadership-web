# Variables de entorno que Vite incrusta en el bundle de producción.
# Esta URL es relativa porque Caddy enruta /api/* al servicio brevo-proxy.
VITE_SUBMIT_URL=/api/submit

# Google Analytics 4 — ID de medición (G-XXXXXXXXXX).
# Reemplaza el valor con tu ID. Si lo dejas vacío, GA queda desactivado.
VITE_GA_ID=

