# Plantilla de variables del stack en producción.
# Copia este fichero a .env (junto al docker-compose.yml) y rellena los valores
# REALES. El .env nunca se sube a git (.gitignore lo excluye).

# Brevo — la API key que creaste en https://app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=xkeysib-rellena-aqui

# ID de la lista en Brevo donde añadir los contactos (Contacts → Lists → URL del listado)
BREVO_LIST_ID=94
